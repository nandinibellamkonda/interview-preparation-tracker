PORT=5000
NODE_ENV=development

# MongoDB Atlas Connection
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/interview-prep?retryWrites=true&w=majority
# If you prefer the alternate variable name, the backend also checks MONGODB_URI.

# JWT Secret
JWT_SECRET=your_jwt_secret_key_change_in_production_12345678

# CORS
CORS_ORIGIN=http://localhost:5173

# File Upload
MAX_FILE_SIZE=5242880

# Frontend URL
FRONTEND_URL=http://localhost:5173

# API Documentation
API_VERSION=v1
